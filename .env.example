# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # yalnızca sunucu — asla client'a sızdırma

# Claude API (yalnızca sunucu)
ANTHROPIC_API_KEY=

# USDA FoodData Central (yalnızca sunucu) — gıda kalori doğrulaması
# Anahtar: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# iyzico ödeme
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# Uygulama
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push bildirimleri (npx web-push generate-vapid-keys ile üret)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=                 # yalnızca sunucu
VAPID_SUBJECT=mailto:ornek@site.com
CRON_SECRET=                       # cron endpoint'ini korur (Vercel cron Bearer ile çağırır)

# RevenueCat — Apple In-App Purchase (StoreKit 2)
# iOS Public SDK key: RevenueCat Dashboard → Project → iOS App → API Keys → Public
NEXT_PUBLIC_REVENUECAT_IOS_KEY=appl_xxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook gizli anahtarı: RevenueCat Dashboard → Integrations → Webhooks → Authorization
REVENUECAT_WEBHOOK_SECRET=
